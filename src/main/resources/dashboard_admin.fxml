<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="auth.controller.DashboardAdminController"
            prefWidth="900" prefHeight="600">

    <top>
        <ToolBar>
            <Label text="Panel de Administración de Usuarios" styleClass="title-4" />
            <Pane fx:id="espaciador" HBox.hgrow="ALWAYS" />
            <Button text="Cerrar sesión" onAction="#cerrarSesion" styleClass="flat" />
        </ToolBar>
    </top>

    <center>
        <SplitPane dividerPositions="0.65">
            <items>
                <!-- Lado Izquierdo: Tabla -->
                <VBox spacing="10">
                    <padding>
                        <Insets top="10" right="5" bottom="10" left="10" />
                    </padding>
                    <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180" />
                            <TableColumn fx:id="colCorreo" text="Correo" prefWidth="250" />
                            <TableColumn fx:id="colRol" text="Rol" prefWidth="100" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- Lado Derecho: Formulario -->
                <VBox spacing="20" maxWidth="350">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="5" />
                    </padding>
                    <Label fx:id="lblTituloFormulario" text="Editar Usuario" styleClass="title-4" />
                    
                    <GridPane hgap="10" vgap="15">
                        <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1" HBox.hgrow="ALWAYS" />

                        <Label text="Correo:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <TextField fx:id="txtCorreo" GridPane.rowIndex="1" GridPane.columnIndex="1" HBox.hgrow="ALWAYS" />

                        <Label text="Rol:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <TextField fx:id="txtRol" GridPane.rowIndex="2" GridPane.columnIndex="1" HBox.hgrow="ALWAYS" />
                    </GridPane>

                    <Separator orientation="HORIZONTAL" />

                    <VBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Nuevo Usuario" onAction="#nuevoUsuario" maxWidth="Infinity" />
                        <Button text="Guardar Cambios" onAction="#guardarCambios" maxWidth="Infinity" styleClass="accent" />
                        <Button text="Eliminar Usuario" onAction="#eliminarUsuario" maxWidth="Infinity" styleClass="danger" />
                    </VBox>
                </VBox>
            </items>
        </SplitPane>
    </center>

</BorderPane>
